{
  "name": "organizador-academico-api",
  "version": "0.1.0",
  "description": "API para Organizador Académico (Node, Express, Sequelize, MySQL, JWT)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/seeders/seed.js",
    "seed:force": "node src/seeders/seed.js --force",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "seed:all": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.25.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "firebase-admin": "^13.7.0",
    "node-cron": "^3.0.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.3.0",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "sequelize-cli": "^6.6.0"
  }
}
